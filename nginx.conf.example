# =============================================================================
# Nginx config for swais.in (Next.js static export deployed on AWS EC2)
# Place at: /etc/nginx/sites-available/swais.in
# Symlink:  sudo ln -s /etc/nginx/sites-available/swais.in /etc/nginx/sites-enabled/
# =============================================================================
#
# IMPORTANT: This site uses Next.js static export (`output: 'export'` +
# `trailingSlash: true`). Each route has its own HTML file:
#   out/index.html              → /
#   out/dashboard/index.html    → /dashboard
#   out/register/index.html     → /register
#   out/login/index.html        → /login
#   out/contact/index.html      → /contact
#   ...etc.
#
# This is NOT a Single Page App. Do NOT use a `try_files ... /index.html`
# catch-all — that would serve the marketing home page for every route.
# =============================================================================

server {
    listen 80;
    listen [::]:80;
    server_name swais.in www.swais.in;

    # Redirect HTTP → HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name swais.in www.swais.in;

    # SSL certs (managed by certbot or your provider)
    ssl_certificate     /etc/letsencrypt/live/swais.in/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/swais.in/privkey.pem;

    # Path to the deployed `out/` folder from `npm run build`
    # Adjust this to wherever you actually deploy the static files
    root /var/www/swais-frontend/out;
    index index.html;

    # Gzip
    gzip on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;
    gzip_min_length 1024;

    # Cache Next.js static assets aggressively
    location /_next/static/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # Static images, fonts, etc.
    location ~* \.(png|jpg|jpeg|gif|ico|svg|webp|woff2?)$ {
        expires 30d;
        add_header Cache-Control "public";
        try_files $uri =404;
    }

    # ====== CRITICAL ROUTING BLOCK ======
    # ✅ Correct: tries the file, then directory's index.html, then 404
    # ❌ Wrong:  try_files $uri $uri/ /index.html;   (serves home page for all routes)
    location / {
        try_files $uri $uri/ $uri/index.html =404;
    }

    # Optional: nicer 404 page
    error_page 404 /404.html;
    location = /404.html {
        internal;
    }
}

# =============================================================================
# Backend API (api.swais.in) — keep existing config or use this
# =============================================================================
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.swais.in;

    ssl_certificate     /etc/letsencrypt/live/api.swais.in/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.swais.in/privkey.pem;

    # Proxy to FastAPI (uvicorn/PM2 on port 5000)
    location / {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket support (if needed)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
